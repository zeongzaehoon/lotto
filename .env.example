# ========================================
# 이 파일을 .env로 복사 후 값을 변경하세요
# cp .env.example .env
# ========================================

# MongoDB
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=         # 강력한 비밀번호 입력
MONGO_DB_NAME=lotto_db

# PostgreSQL (Airflow + MLflow metadata)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=                  # 강력한 비밀번호 입력
POSTGRES_DB=airflow

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:<POSTGRES_PASSWORD>@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=          # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__SECRET_KEY=     # openssl rand -hex 32
AIRFLOW_UID=50000

# FastAPI
BACKEND_PORT=8000
MONGODB_URL=mongodb://admin:<MONGO_PASSWORD>@mongodb:27017/lotto_db?authSource=admin

# Frontend
VITE_API_URL=
